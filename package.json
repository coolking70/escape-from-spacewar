{
  "name": "spacewar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:static": "node scripts/build-static.mjs",
    "preview": "vite preview",
    "serve:static": "node static/serve.mjs",
    "test": "npm run test:acceptance",
    "test:det": "tsc -p scripts/tsconfig.test.json && node scripts/emit-cjs-pkg.mjs && node .tmp-test/scripts/determinism-test.js",
    "test:acceptance": "tsc -p scripts/tsconfig.test.json && node scripts/emit-cjs-pkg.mjs && node .tmp-test/scripts/acceptance-test.js",
    "test:stress": "tsc -p scripts/tsconfig.test.json && node scripts/emit-cjs-pkg.mjs && node .tmp-test/scripts/stress-test.js",
    "test:campaign": "tsc -p scripts/tsconfig.test.json && node scripts/emit-cjs-pkg.mjs && node .tmp-test/scripts/campaign-test.js",
    "test:strategy": "tsc -p scripts/tsconfig.test.json && node scripts/emit-cjs-pkg.mjs && node .tmp-test/scripts/strategic-test.js",
    "test:browser": "node scripts/strategy-browser-test.mjs --target=development",
    "test:browser:production": "node scripts/strategy-browser-test.mjs --target=production",
    "test:browser:static": "node scripts/strategy-browser-test.mjs --target=static"
  },
  "dependencies": {
    "three": "0.160.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/three": "0.160.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.58.2",
    "typescript": "^5.4.0",
    "vite": "^7.3.6"
  }
}
